# Variáveis usadas pelo docker-compose para subir MySQL + backend + frontend.
# Copie este arquivo para .env e ajuste se necessário:
#   cp .env.example .env

# ---- MySQL ----
MYSQL_USER=financeiro
MYSQL_PASSWORD=financeiro_pass
MYSQL_DATABASE=financeiro_db
MYSQL_ROOT_PASSWORD=root_pass
MYSQL_PORT=3306

# ---- Backend ----
# URL que o backend usa para conectar no MySQL (host = nome do serviço Docker).
DATABASE_URL=mysql+pymysql://financeiro:financeiro_pass@mysql:3306/financeiro_db

# Em produção, gere uma chave forte com:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=*

# ---- Portas expostas no host ----
BACKEND_PORT=8000
FRONTEND_PORT=5173
