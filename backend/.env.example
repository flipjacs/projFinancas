# ---- Application ----
APP_NAME=Personal Financial Planning System
APP_ENV=development         # development | staging | production | test
DEBUG=true                  # MUST be false in production
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR

# ---- Database ----
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=financeiro
MYSQL_PASSWORD=financeiro_pass
MYSQL_DATABASE=financeiro_db
MYSQL_ROOT_PASSWORD=root_pass

DATABASE_URL=mysql+pymysql://financeiro:financeiro_pass@mysql:3306/financeiro_db

# ---- JWT ----
# In production, this MUST be a 32+ char random string and APP_ENV=production
# refuses to boot otherwise. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ---- CORS ----
# Comma-separated list of allowed origins. Production refuses "*".
CORS_ORIGINS=*

# ---- Rate limiting (slowapi) ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_WRITE=60/minute

# ---- Cache ----
# When REDIS_URL is set the app uses Redis; otherwise it falls back to a
# thread-safe in-memory TTL cache. Leave unset for single-process deploys.
CACHE_DEFAULT_TTL_SECONDS=60
# REDIS_URL=redis://redis:6379/0

# ---- CSV import ----
CSV_IMPORT_MAX_ROWS=5000
CSV_IMPORT_MAX_BYTES=2097152
