# Variáveis para rodar o backend localmente (fora do Docker).
# No fluxo Docker, o docker-compose já injeta as variáveis a partir do .env da raiz.
#
# Para rodar local:
#   cp .env.example .env
#   ajuste os valores e rode `uvicorn app.main:app --reload`

# ---- Application ----
APP_NAME=Financeiro
APP_ENV=development         # development | staging | production | test
DEBUG=true                  # MUST be false in production
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR

# ---- Database ----
# Para rodar com o MySQL do docker-compose:
DATABASE_URL=mysql+pymysql://financeiro:financeiro_pass@localhost:3306/financeiro_db

# ---- JWT ----
# Em produção, gere uma chave forte (32+ caracteres) com:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ---- CORS ----
# Lista de origens permitidas separadas por vírgula. Produção não aceita "*".
CORS_ORIGINS=*

# ---- Rate limiting (slowapi) ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_WRITE=60/minute

# ---- Cache ----
# Se REDIS_URL estiver setado, o app usa Redis; caso contrário, usa cache TTL em memória.
CACHE_DEFAULT_TTL_SECONDS=60
# REDIS_URL=redis://localhost:6379/0

# ---- CSV import ----
CSV_IMPORT_MAX_ROWS=5000
CSV_IMPORT_MAX_BYTES=2097152
